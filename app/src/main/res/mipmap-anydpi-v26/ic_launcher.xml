<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/zen_background"/>
    <foreground>
        <inset android:insetTop="25%"
               android:insetBottom="25%"
               android:insetLeft="25%"
               android:insetRight="25%">
            <shape android:shape="oval">
                <gradient
                    android:startColor="#00E5FF"
                    android:endColor="#B100FF"
                    android:type="sweep" />
                <stroke
                    android:width="4dp"
                    android:color="#00E5FF" />
            </shape>
        </inset>
    </foreground>
</adaptive-icon>
